{
    "name": "northbees/autotrader-api",
    "description": "Auto Trader API Integration",
    "license": "MIT",
    "authors": [
        {
            "name": "Steve Smith",
            "email": "steven@sd-smith.co.uk",
            "homepage": "https://github.com/NorthBees/"
        }
    ],
    "homepage": "https://github.com/northbees/autotrader-api",
    "keywords": ["Laravel", "AutoTraderApi"],
    "require": {
        "illuminate/support": "~10"
    },
    "require-dev": {
        "phpunit/phpunit": "~9.0",
        "orchestra/testbench": "~7"
    },
    "autoload": {
        "psr-4": {
            "NorthBees\\AutoTraderApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NorthBees\\AutoTraderApi\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NorthBees\\AutoTraderApi\\AutoTraderApiServiceProvider"
            ]
        }
    }
}
