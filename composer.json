{
    "name": "northbees/autotraderapi",
    "description": "Auto Trader API Integration",
    "license": "MIT",
    "authors": [
        {
            "name": "Author Name",
            "email": "author@email.com",
            "homepage": "http://author.com"
        }
    ],
    "homepage": "https://github.com/northbees/autotraderapi",
    "keywords": ["Laravel", "AutotraderApi"],
    "require": {
        "illuminate/support": "~9"
    },
    "require-dev": {
        "phpunit/phpunit": "~9.0",
        "orchestra/testbench": "~7"
    },
    "autoload": {
        "psr-4": {
            "NorthBees\\AutotraderApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NorthBees\\AutotraderApi\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NorthBees\\AutotraderApi\\AutotraderApiServiceProvider"
            ],
            "aliases": {
                "AutotraderApi": "NorthBees\\AutotraderApi\\Facades\\AutotraderApi"
            }
        }
    }
}
